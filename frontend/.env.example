# =============================================================================
# AOXC NEURAL OS - ENVIRONMENT TEMPLATE (.env.example)
# =============================================================================
# Talimatlar: Bu dosyayı '.env' adıyla kopyalayın ve kendi anahtarlarınızı girin.
# ÖNEMLİ: Gerçek '.env' dosyasını asla Git veya versiyon kontrolüne eklemeyin.

# --- [NEURAL ENGINE CONFIG] ---
# @notice Google AI Studio'dan anahtarınızı alın: https://aistudio.google.com/
VITE_GEMINI_API_KEY="your_gemini_api_key_here"
VITE_APP_URL="https://aoxcore.com"

# --- [BLOCKCHAIN INFRASTRUCTURE - MAINNET (ID: 196)] ---
VITE_RPC_URL_MAINNET="https://rpc.xlayer.tech"
VITE_CHAIN_ID_MAINNET="196"

# --- [BLOCKCHAIN INFRASTRUCTURE - TESTNET (ID: 195)] ---
VITE_RPC_URL_TESTNET="https://testrpc.xlayer.tech"
VITE_CHAIN_ID_TESTNET="195"

# --- [CORE SMART CONTRACT ADDR - MAINNET] ---
# AOXC Token
VITE_AOXC_TOKEN_ADDR="0xeb9580c3946bb47d73aae1d4f7a94148b554b2f4"
# AOXC Core Registry (Sözleşme Asıl)
VITE_AOXC_CORE_ADDR="0x97bdd1fd1caf756e00efd42eba9406821465b365"
# AOXC Multi-Sig Vault
VITE_AOXC_MULTISIG_ADDR="0x20c0dd8b6559912acfac2ce061b8d5b19db8ca84"

# --- [CORE SMART CONTRACT ADDR - TESTNET] ---
VITE_AOXC_TOKEN_ADDR_TESTNET="0x..."
VITE_AOXC_CORE_ADDR_TESTNET="0x..."
VITE_AOXC_MULTISIG_ADDR_TESTNET="0x..."

# --- [SYSTEM PARAMETERS] ---
# development | production
NODE_ENV="development"
VITE_SYSTEM_MODE="development"
PORT=3000

# --- [TELEMETRY & AUDIT] ---
VITE_HEARTBEAT_INTERVAL=12000
VITE_API_ENDPOINT="https://aoxcore.com/api/status.php"

# =============================================================================
# END OF TEMPLATE - AOXCORE NEURAL KERNEL v2.5
# =============================================================================
