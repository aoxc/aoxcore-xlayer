# ==============================================================================
# 🧠 AOXCORE PROTOCOL - NEURAL ARCHITECTURE GIT SPEC
# DESCRIPTION: Audit-Level "Fortress Edition" for Hybrid Web3 Projects
# VERSION: 5.0.0 (Global Standard)
# ==============================================================================

# --- [CORE DEPENDENCIES] ---
# Never commit local dependencies.
node_modules/
jspm_packages/
lib/
.pnp.*
.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/
!.yarn/versions/

# --- [PRODUCTION & COMPILER BUILDS] ---
# Compiled assets, distribution bundles, and contract artifacts.
dist/
build/
out/
cache/
artifacts/
.next/
bin/
obj/
foundry.lock

# --- [ENVIRONMENT & SECRETS] ---
# CRITICAL: Prevent API keys and secrets from leaking.
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.local
# Neural Keys & Signatures
secrets/
*.key
*.pem
*.json.gpg
# Allow example template for team onboarding
!.env.example

# --- [DIAGNOSTICS & LOGS] ---
# Runtime logs, crash reports and debug info.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
logs/
panic.log
anvil.log
*.trace

# --- [TESTING & COVERAGE] ---
# Reports generated by Foundry, Jest, or Vitest.
coverage/
*.lcov
.nyc_output
.cypress/screenshots/
.cypress/videos/
gas-report.txt
.gas-snapshot
neural-audit-results/

# --- [BLOCKCHAIN BROADCAST DATA] ---
# Only keep the latest deployment record, ignore transaction history.
broadcast/
!broadcast/*/run-latest.json
/broadcast/*/31337/
/broadcast/**/dry-run/

# --- [IDE & SYSTEM FILES] ---
# Local editor settings and OS-specific clutter.
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini

# VS Code specific (allow critical team configs)
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json

# WebStorm / IntelliJ
.idea/
*.iws
*.iml
*.ipr

# --- [VITE & METADATA CACHE] ---
# Cache directories and temporary metadata.
.vite/
.eslintcache
.stylelintcache
.cache/
.parcel-cache
# If metadata.json is generated/temporary, uncomment the next line:
# metadata.json

# --- [TEMPORARY FILES] ---
*.swp
*.bak
*.tmp
*.temp
*~
