# 1. Ana dizine çık
cd ~/Work/AOXCORE

# 2. Varsa alt klasörlerdeki kalıntıları temizle (Çakışmayı önlemek için)
rm -f backend/.gitignore frontend/.gitignore cli/.gitignore contracts/.gitignore

# 3. Master .gitignore dosyasını oluştur (Verdiğin içeriği buraya yazıyoruz)
cat <<EOF > .gitignore
# ==============================================================================
# 🧠 AOXCORE PROTOCOL | NEURAL ARCHITECTURE GIT SPEC
# VERSION: 6.0.0 "Architect Edition" - Hybrid Protection
# ==============================================================================

# --- 🛠️ FOUNDRY & COMPILER (ROOT SPECIFIC) ---
/out/
/cache/
/artifacts/
foundry.lock

# --- 📦 DEPENDENCIES & LIBRARIES ---
/lib/
node_modules/
dist/
build/
.vite/
.yarn/
!.yarn/patches/
!.yarn/releases/

# --- 🔐 SECRETS & NEURAL KEYS ---
.env
.env.*
!.env.example
*.key
*.pem
*.json.gpg
secrets/
.secret*

# --- 📡 BLOCKCHAIN & SENTINEL DATA ---
broadcast/
!broadcast/*/run-latest.json
/broadcast/*/31337/
/broadcast/**/dry-run/
anvil.log
*.trace

# --- 📊 AUDIT & NEURAL REPORTS ---
reports/
coverage/
*.lcov
gas-report.txt
.gas-snapshot
neural-audit-results/

# --- 🚀 RUNTIME & LOGS ---
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
panic.log

# --- 💻 OS & IDE ---
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
.idea/
*.swp
*.bak
*.tmp
*.temp
EOF

echo "🛡️ Master-Shield .gitignore aktif edildi."
