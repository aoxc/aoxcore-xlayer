# ==============================================================================
# 🛡️ AOXCAN PROTOCOL | REFINED GITIGNORE SPEC
# VERSION: 7.3.0 "Transparent-Sovereign"
# ==============================================================================

# --- [🤖 AI & HEAVY NEURAL ASSETS] ---
# Exclude large model binaries and training checkpoints
**/model_hub/
**/outputs/**/checkpoint-*/
**/*.safetensors
**/*.onnx
**/*.pt
**/*.pth
**/*.bin
**/data/*.jsonl

# --- [⚙️ DEVELOPMENT & RUNTIME] ---
**/__pycache__/
**/*.pyc
.ipynb_checkpoints/
*.log
**/yedek/

# --- [🛠️ BLOCKCHAIN & FOUNDRY] ---
/out/
/cache/
/artifacts/
foundry.lock

# --- [🔐 SECURITY & SENSITIVE DATA] ---
# Critical: Never expose private keys or environment variables
.env
.env.*
!.env.example
*.key
*.pem
*.json.gpg
**/secrets/
**/config_private.py

# --- [📡 NETWORK BROADCASTS] ---
broadcast/
!broadcast/*/run-latest.json
/broadcast/*/31337/
anvil.log

# --- [💻 SYSTEM & IDE SPECIFIC] ---
.DS_Store
.vscode/
.idea/
*.swp
*.bak
*.tmp
